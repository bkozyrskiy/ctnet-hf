#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -lt 2 ] || [ "$#" -gt 3 ]; then
  echo "Usage: scripts/check_clean_inference MODEL_OR_REPO_ID REAL_TRIAL.npy [EXPECTED_LABEL]" >&2
  exit 2
fi

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
MODEL="$1"
if [ -d "${MODEL}" ]; then
  MODEL="$(cd "${MODEL}" && pwd)"
fi
TRIAL="$(cd "$(dirname "$2")" && pwd)/$(basename "$2")"
EXPECTED="${3:-}"
TMP="$(mktemp -d "${TMPDIR:-/tmp}/ctnet-clean-inference.XXXXXX")"
trap 'rm -rf "${TMP}"' EXIT

"${CLEAN_PYTHON:-python}" -m venv "${TMP}/venv"
"${TMP}/venv/bin/python" -m pip install --quiet --upgrade pip
"${TMP}/venv/bin/python" -m pip wheel --quiet --no-deps --wheel-dir "${TMP}/wheels" "${ROOT}"
"${TMP}/venv/bin/python" -m pip install --quiet \
  --index-url https://download.pytorch.org/whl/cpu \
  "${CLEAN_TORCH:-torch==2.3.1+cpu}"
"${TMP}/venv/bin/python" -m pip install --quiet \
  "numpy>=1.23,<2" "transformers>=4.39,<5"
"${TMP}/venv/bin/python" -m pip install --quiet --no-deps \
  "${TMP}"/wheels/ctnet_hf-*.whl

args=(--model "${MODEL}" --trial "${TRIAL}")
if [ -n "${EXPECTED}" ]; then
  args+=(--expected-prediction "${EXPECTED}")
fi
cd "${TMP}"
env -u PYTHONPATH "${TMP}/venv/bin/python" -m ctnet_hf.inference "${args[@]}"
